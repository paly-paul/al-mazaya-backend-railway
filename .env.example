# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (disabled)
# GEMINI_API_KEY=
# GEMINI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Database
# Local/dev default: SQLite file created automatically by the backend.
DATABASE_URL=sqlite:///./data/mazaya_fm.db

# Optional production/external PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:5432/mazaya_fm

# Application
SECRET_KEY=mazaya-local-dev-secret-8f4c2b9a7e1d43f6a92c5d0b3e7a1f65

# CORS / allowed origins
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=*

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@Mazaya2025

# Agent config
AUTO_APPROVAL_THRESHOLD_KD=500
LEAD_SCORE_HOT_THRESHOLD=70
LEAD_SCORE_WARM_THRESHOLD=40
VENDOR_DISPATCH_TIMEOUT_MINUTES=30
P1_SLA_HOURS=2
P2_SLA_HOURS=8
P3_SLA_HOURS=48

# Briefing schedule (cron, Kuwait time)
BRIEFING_DAILY_CRON=0 8 * * *
BRIEFING_WEEKLY_CRON=0 9 * * 1
